    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "reka-ui": "^2.9.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "gh-pages": "^6.3.0",
    "tw-animate-css": "^1.4.0",
